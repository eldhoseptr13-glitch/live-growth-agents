# Copy this file to `.env` and fill in the values (see SETUP-COWORK.md). Never commit `.env`.
# No Anthropic API key is needed — Claude in Cowork writes the audit.

GOOGLE_ADS_DEVELOPER_TOKEN=          # Google Ads MCC → Tools → API Center (needs Basic access for live accounts)
GOOGLE_ADS_CLIENT_ID=               # Google Cloud OAuth client id (ends in .apps.googleusercontent.com)
GOOGLE_ADS_CLIENT_SECRET=           # Google Cloud OAuth client secret
GOOGLE_ADS_REFRESH_TOKEN=           # minted in the OAuth Playground (SETUP-COWORK.md Step 6)
GOOGLE_ADS_CUSTOMER_ID=             # 10 digits, no dashes — the account to audit
GOOGLE_ADS_LOGIN_CUSTOMER_ID=       # optional — the MCC's 10-digit id, only if you reach the account through the manager
GOOGLE_ADS_API_VERSION=v24          # bump if this version is sunset (HTTP 404 from the API)
